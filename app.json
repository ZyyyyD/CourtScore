{
  "expo": {
    "name": "COURTSCORE",
    "slug": "courtscore",
    "version": "1.0.0",
    "scheme": "courtscore",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.courtscore.app"
    },
    "android": {
      "package": "com.courtscore.app",
      "adaptiveIcon": {
        "backgroundColor": "#1a472a",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
